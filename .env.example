# Kopieer dit bestand naar .env en vul de waarden in
# Voeg .env toe aan je .gitignore — dit bestand NOOIT op GitHub!

# Supabase (haal op via supabase.com → jouw project → Settings → API)
SUPABASE_URL=https://jouwproject.supabase.co
SUPABASE_SERVICE_KEY=eyJhb...jouw_service_role_key

# JWT geheim — verzin een lange willekeurige string (min 32 tekens)
JWT_SECRET=verander_dit_naar_een_lange_willekeurige_string_hier

# Frontend URL (voor CORS) — na GitHub Pages deploy aanpassen
ALLOWED_ORIGINS=http://localhost:3000,https://jouwnaam.github.io

# Poort (Railway stelt dit automatisch in)
PORT=3000
